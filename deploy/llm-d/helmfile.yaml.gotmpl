# llm-d helmfile — per-model deployment pattern
#
# Each model has its own directory under deploy/ with:
#   model-cache-pvc.yaml    — PersistentVolumeClaim for HF model cache
#   modelservice-values.yaml — vLLM worker configuration (or leaderworkerset.yaml for PP)
#   inferencepool-values.yaml — EPP routing configuration
#
# Charts: llm-d-infra (CRDs), inferencepool (EPP), llm-d-modelservice (vLLM workers)
environments:
  default:
    values:
    - env: default

---
repositories:
# llm-d-deployer (ghcr.io/llm-d) was deprecated Oct 2025.
# Charts now live in llm-d-incubation HTTP repos and upstream GAIE OCI registry.
- name: llm-d-infra
  url: https://llm-d-incubation.github.io/llm-d-infra/
- name: llm-d-modelservice
  url: https://llm-d-incubation.github.io/llm-d-modelservice/
# Gateway API Inference Extension: upstream inferencepool chart
- name: gaie
  url: registry.k8s.io/gateway-api-inference-extension/charts
  oci: true

releases:
  # ── Shared Infrastructure ──────────────────────────────────────────────────
  # InferencePool CRDs and Gateway configuration
  - name: llm-d-infra
    namespace: token-labs
    chart: llm-d-infra/llm-d-infra
    version: v1.3.6
    values:
    - values/infra.yaml

  # ── Nemotron-Llama 8B (spark-01) ──────────────────────────────────────────
  # PVC: kubectl apply -f deploy/nemotron-8b/model-cache-pvc.yaml
  - name: llm-d-inferencepool
    namespace: token-labs
    chart: gaie/inferencepool
    version: v1.3.0
    needs:
    - token-labs/llm-d-infra
    values:
    - ../nemotron-8b/inferencepool-values.yaml

  - name: llm-d-modelservice
    namespace: token-labs
    chart: llm-d-modelservice/llm-d-modelservice
    version: v0.4.5
    needs:
    - token-labs/llm-d-infra
    values:
    - ../nemotron-8b/modelservice-values.yaml
    strategicMergePatches:
    - apiVersion: apps/v1
      kind: Deployment
      metadata:
        name: llm-d-modelservice-decode
      spec:
        strategy:
          rollingUpdate:
            maxSurge: 0
            maxUnavailable: 1

  # ── Qwen3 14B NVFP4 (spark-01) ────────────────────────────────────────────
  # PVC: kubectl apply -f deploy/qwen3-14b/model-cache-pvc.yaml
  - name: llm-d-inferencepool-qwen3-14b
    namespace: token-labs
    chart: gaie/inferencepool
    version: v1.3.0
    needs:
    - token-labs/llm-d-infra
    values:
    - ../qwen3-14b/inferencepool-values.yaml

  - name: llm-d-modelservice-qwen3-14b
    namespace: token-labs
    chart: llm-d-modelservice/llm-d-modelservice
    version: v0.4.5
    needs:
    - token-labs/llm-d-infra
    values:
    - ../qwen3-14b/modelservice-values.yaml
    strategicMergePatches:
    - apiVersion: apps/v1
      kind: Deployment
      metadata:
        name: llm-d-modelservice-qwen3-14b-decode
      spec:
        strategy:
          rollingUpdate:
            maxSurge: 0
            maxUnavailable: 1

  # ── gpt-oss-120gb PP=2 (spark-01 + spark-02, LeaderWorkerSet) ─────────────
  # PVCs: kubectl apply -f deploy/gpt-oss/model-cache-pvcs.yaml
  # LWS:  kubectl apply -f deploy/gpt-oss/leaderworkerset.yaml
  # This release only creates the InferencePool + EPP for routing.
  - name: llm-d-inferencepool-gpt-oss
    namespace: token-labs
    chart: gaie/inferencepool
    version: v1.3.0
    needs:
    - token-labs/llm-d-infra
    values:
    - ../gpt-oss/inferencepool-values.yaml
