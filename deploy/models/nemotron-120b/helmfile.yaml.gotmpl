# llm-d helmfile — Nemotron-3-Super-120B NVFP4, single-node
#
# Architecture:
#   spark-01: decode-only (TP=1, 1 replica, no P/D disaggregation)
#   KV transfer: none (single node)
#   Gateway: Envoy at 192.168.1.200, model service at nemotron-120b-vllm ClusterIP
#
# Model: nvidia/NVIDIA-Nemotron-3-Super-120B-A12B-NVFP4
#   - 120B params, NVFP4 (~74.8GB weights cached on PVC)
#   - Requires gptq_marlin/VLLM_NVFP4_GEMM_BACKEND=marlin for SM 12.1 (GB10)
#   - VLLM_USE_FLASHINFER_MOE_FP4=0 required (not supported on single-GPU SM121)

{{ $ns := env "NAMESPACE" | default "token-labs" }}

repositories:
  - name: llm-d-modelservice
    url: https://llm-d-incubation.github.io/llm-d-modelservice/
  - name: gaie
    url: registry.k8s.io/gateway-api-inference-extension/charts
    oci: true

releases:
  - name: gaie-nemotron-120b
    namespace: {{ $ns }}
    chart: gaie/inferencepool
    version: v1.4.0
    installed: true
    values:
      - gaie-values.yaml

  - name: ms-nemotron-120b
    namespace: {{ $ns }}
    chart: llm-d-modelservice/llm-d-modelservice
    version: v0.4.9
    installed: true
    needs:
      - {{ $ns }}/gaie-nemotron-120b
    values:
      - modelservice-values.yaml
